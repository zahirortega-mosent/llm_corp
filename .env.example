# Bloque 1/2 - router, modelos y presupuestos de contexto
ENABLE_NEW_ROUTER=true
ENABLE_LLM_CLASSIFIER=false
ENABLE_INSTITUTIONAL_MEMORY=false
ENABLE_SCOPE_ENFORCEMENT=false
ENABLE_CONTEXT_RESOLVER=true
INSTITUTIONAL_MEMORY_TOP_K=5
INSTITUTIONAL_MEMORY_REQUIRE_APPROVED=true
INSTITUTIONAL_MEMORY_ENABLE_VECTOR=false
INSTITUTIONAL_MEMORY_CHUNK_SIZE=1200
INSTITUTIONAL_MEMORY_CHUNK_OVERLAP=150
INSTITUTIONAL_MEMORY_VECTOR_DIM=1024
LLM_FAST_MODEL=qwen3:4b
LLM_ANALYST_MODEL=qwen3:14b
LLM_CLASSIFIER_MODEL=qwen3:4b
LLM_EMBEDDING_MODEL=qwen3-embedding:0.6b
LLM_DEFAULT_CONTEXT=8192
LLM_LONG_CONTEXT=16384
LLM_CLASSIFIER_TIMEOUT_SECONDS=30
LLM_ANALYST_TIMEOUT_SECONDS=180
LLM_ALLOW_THINKING=false
